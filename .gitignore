# dependencies & build output
node_modules/
release/
# Expo prebuild output — regenerable via `expo prebuild`, hundreds of MB, and
# contains the default debug keystore. Never commit.
helm-mobile/android/
helm-mobile/ios/

# design mockups / visual prototypes (kept local, not part of the shipped repo)
helm-desktop-prototype/
helm-mobile-prototype/

# logs & shell/terminal history dumps
*.log
*history*

# secrets & key material (never commit)
.env*
*.key
*.pem
*.pfx
*.p12

# local agent / tooling config (machine-specific)
.claude/
.playwright-mcp/

# isolated experimental work (removable without breaking core)
/experimental/private/

# internal planning & design docs (never push)
plan.md
product.md
design.md
handoff.md
docs/LEARNINGS.md
