{
  "name": "helm-mobile",
  "version": "1.0.0",
  "description": "HELM Mobile — the phone-side control surface. Pairs with the laptop by QR, lists allowlisted projects + detected agents, submits a task, and streams the agent's output back. Holds no code or secrets.",
  "license": "MIT",
  "private": true,
  "main": "index.js",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web"
  },
  "dependencies": {
    "expo": "~53.0.0",
    "expo-camera": "~16.1.5",
    "expo-font": "~13.3.1",
    "expo-secure-store": "~14.2.3",
    "expo-status-bar": "~2.2.3",
    "react": "19.0.0",
    "react-native": "0.79.2",
    "react-native-safe-area-context": "5.4.0",
    "react-native-screens": "~4.10.0",
    "@expo/vector-icons": "^14.1.0",
    "@react-navigation/native": "^7.0.14",
    "@react-navigation/native-stack": "^7.2.0"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2"
  }
}
