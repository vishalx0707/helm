{
  "expo": {
    "name": "HELM",
    "slug": "helm-mobile",
    "version": "1.1.0",
    "orientation": "portrait",
    "scheme": "helm",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#0A0A0B",
    "newArchEnabled": false,
    "splash": {
      "backgroundColor": "#0A0A0B",
      "resizeMode": "contain"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "infoPlist": {
        "NSCameraUsageDescription": "HELM uses the camera to scan the pairing QR code shown by HELM Desktop on your laptop."
      }
    },
    "android": {
      "package": "com.helm.mobile",
      "edgeToEdgeEnabled": true,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "HELM uses the camera to scan the pairing QR code shown by HELM Desktop on your laptop."
        }
      ],
      "expo-secure-store",
      "expo-font"
    ]
  }
}
